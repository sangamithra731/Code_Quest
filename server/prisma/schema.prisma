generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  level        Int      @default(1)
  xp           Int      @default(0)
  coins        Int      @default(0)
  streak       Int      @default(0)
  lastActiveAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]
  progress      Progress[]
  badges        UserBadge[]
  certificates  Certificate[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Language {
  id          String   @id @default(uuid())
  slug        String   @unique // "python", "javascript"
  name        String
  description String   @db.Text
  icon        String? // emoji or icon key
  difficulty  String   @default("Beginner") // Beginner | Intermediate | Advanced
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  modules      Module[]
  certificates Certificate[]

  @@map("languages")
}

model Module {
  id         String   @id @default(uuid())
  languageId String
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  slug       String
  title      String
  order      Int      @default(0)

  levels Level[]

  @@unique([languageId, slug])
  @@map("modules")
}

model Level {
  id        String   @id @default(uuid())
  moduleId  String
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  slug      String
  title     String
  order     Int      @default(0)
  theory    String   @db.Text
  examples  Json // [{ code, explanation }]
  practice  Json // [{ prompt, starterCode, solution }]
  xpReward  Int      @default(50)

  questions Question[]
  progress  Progress[]

  @@unique([moduleId, slug])
  @@map("levels")
}

model Question {
  id            String @id @default(uuid())
  levelId       String
  level         Level  @relation(fields: [levelId], references: [id], onDelete: Cascade)
  question      String @db.Text
  options       Json // ["opt1", "opt2", "opt3", "opt4"]
  correctIndex  Int
  order         Int    @default(0)

  @@map("questions")
}

model Progress {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  levelId     String
  level       Level     @relation(fields: [levelId], references: [id], onDelete: Cascade)
  completed   Boolean   @default(false)
  bestScore   Int       @default(0) // percentage, 0-100
  attempts    Int       @default(0)
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([userId, levelId])
  @@map("progress")
}

model Badge {
  id          String @id @default(uuid())
  code        String @unique // "first_steps", "seven_day_streak"
  name        String
  description String
  icon        String @default("★")

  users UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Certificate {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  languageId String
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  issuedAt   DateTime @default(now())

  @@unique([userId, languageId])
  @@map("certificates")
}